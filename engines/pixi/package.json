{
	"name": "engine-pixi",
	"version": "0.0.0",
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./assets/*": "./assets/*",
		"./vite-plugins": {
			"types": "./vite-plugins.d.ts",
			"default": "./vite-plugins.js"
		},
		"./vite-config": {
			"types": "./vite-config.d.ts",
			"default": "./vite-config.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"dev": "vite",
		"build": "tsc",
		"check": "tsc",
		"test": "vitest run --config vitest.config.ts",
		"generate-spritesheet": "tsx scripts/generate-spritesheet.ts",
		"postgenerate-spritesheet": "cp -r public/pixi-assets ../../apps/browser/public/"
	},
	"dependencies": {
		"engine-terrain": "workspace:*",
		"mutts": "^1.0.14",
		"pixi.js": "^8.14.3",
		"ssh": "workspace:*",
		"typescript": "~5.8.3",
		"vite": "^8.0.10",
		"vitest": "^4.1.4"
	},
	"devDependencies": {
		"@types/node": "^24.10.4",
		"@types/spritesmith": "^3.4.5",
		"sharp": "^0.34.5",
		"spritesmith": "^3.5.1"
	}
}
