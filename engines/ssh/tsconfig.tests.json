{
	"extends": "./tsconfig.app.json",
	"compilerOptions": {
		"noEmit": true,
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tests.tsbuildinfo"
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.d.ts",
		"assets/**/*.ts",
		"../rules/src/**/*.ts",
		"../terrain/src/**/*.ts",
		"tests/**/*.ts",
		"tests/**/*.d.ts"
	]
}
