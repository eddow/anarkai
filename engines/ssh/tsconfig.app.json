{
	"compilerOptions": {
		"composite": true,
		"target": "ES2023",
		"lib": ["ES2023"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowSyntheticDefaultImports": true,
		"allowImportingTsExtensions": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"skipLibCheck": true,
		"useDefineForClassFields": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"strict": true,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noFallthroughCasesInSwitch": true,
		"sourceMap": true,
		"paths": {
			"ssh/*": ["./src/lib/*"],
			"engine-rules": ["../rules/src/index.ts"],
			"engine-terrain": ["../terrain/src/index.ts"],
			"engine-terrain/hex": ["../terrain/src/hex/index.ts"]
		}
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.d.ts",
		"assets/**/*.ts",
		"../rules/src/**/*.ts",
		"../terrain/src/**/*.ts"
	]
}
