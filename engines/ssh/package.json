{
	"name": "ssh",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./*": "./src/lib/*.ts",
		"./debug": "./src/lib/debug.ts",
		"./assets/*": "./assets/*",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json",
		"check": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json",
		"test": "node ./scripts/run-vitest.mjs",
		"test:trace-progress": "node ./scripts/trace-vitest-progress.mjs",
		"test:core": "vitest run tests/unit/work_logic.test.ts tests/unit/pathfinding.test.ts tests/unit/storage.test.ts",
		"test:watch": "vitest",
		"test:verbose": "vitest run"
	},
	"dependencies": {
		"arktype": "^2.1.22",
		"anarkai-core": "workspace:*",
		"engine-rules": "workspace:*",
		"engine-terrain": "workspace:*",
		"eventemitter3": "^5.0.1",
		"mutts": "^1.0.14",
		"npc-script": "^1.0.0",
		"typescript": "~5.8.3",
		"vitest": "^4.1.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/node": "25.0.10"
	},
	"packageManager": "pnpm@10.7.1+sha512.2d92c86b7928dc8284f53494fb4201f983da65f0fb4f0d40baafa5cf628fa31dae3e5968f12466f17df7e97310e30f343a648baea1b9b350685dafafffdf5808"
}
