{
	"extends": "./tsconfig.app.json",
	"compilerOptions": {
		"noEmit": true,
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.spec.tsbuildinfo",
		"jsx": "react",
		"jsxFactory": "h",
		"jsxFragmentFactory": "Fragment",
		"types": ["vitest/globals", "vite/client"]
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx",
		"src/**/*.d.ts",
		"sandbox/**/*.ts",
		"sandbox/**/*.tsx",
		"assets/**/*.ts",
		"assets/**/*.tsx",
		"../../engines/pixi/src/**/*.ts",
		"../../engines/pixi/src/**/*.d.ts",
		"../../engines/pixi/assets/**/*.ts",
		"../../engines/rules/src/**/*.ts",
		"../../engines/ssh/src/**/*.ts",
		"../../engines/ssh/tests/**/*.ts",
		"../../engines/ssh/tests/**/*.d.ts",
		"../../engines/terrain/src/**/*.ts",
		"../../engines/ssh/assets/**/*.ts",
		"tests/**/*.ts",
		"tests/**/*.tsx",
		"tests/**/*.d.ts",
		"src/**/*.{spec,test}.ts",
		"src/**/*.{spec,test}.tsx"
	],
	"exclude": []
}
