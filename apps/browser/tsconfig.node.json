{
	"compilerOptions": {
		"composite": true,
		"noEmit": true,
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
		"target": "ES2022",
		"lib": ["ES2022"],
		"module": "ESNext",
		"skipLibCheck": true,
		/* Bundler mode */
		"moduleResolution": "bundler",
		"verbatimModuleSyntax": true,
		"moduleDetection": "force",
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"types": ["node"],
		/* Linting */
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"erasableSyntaxOnly": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedSideEffectImports": true,
		/* Path mapping */
		"baseUrl": ".",
		"paths": {
			"$lib/*": ["./src/lib/*"],
			"$assets/*": ["./assets/*"],
			"$components/*": ["./src/components/*"],
			"@app/*": ["./src/*"],
			"@sursaut/*": ["node_modules/sursaut-ts/src/*"],
			"@sursaut/runtime": ["node_modules/sursaut-ts/src/lib/index.ts"],
			"@sursaut/runtime/jsx-runtime": [
				"node_modules/sursaut-ts/src/runtime/jsx-runtime.ts"
			],
			"@sursaut/runtime/jsx-dev-runtime": [
				"node_modules/sursaut-ts/src/runtime/jsx-dev-runtime.ts"
			]
		}
	},
	"include": [
		"vite.config.ts",
		"vitest.config.ts",
		"playwright.config.ts",
		"../../engines/pixi/vite-plugins.ts",
		"../../engines/pixi/vite-config.ts",
		"../../engines/ssh/vite-plugin-css-tag.ts"
	]
}
